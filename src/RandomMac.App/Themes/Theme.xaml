<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- Dark theme -->
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E2E" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#181825" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#282840" />
            <SolidColorBrush x:Key="CardBackgroundTransparentBrush" Color="#CC282840" />
            <SolidColorBrush x:Key="LinkForegroundBrush" Color="#89B4FA" />

            <SolidColorBrush x:Key="NotifSuccessBackgroundBrush" Color="#2D3D2D" />
            <SolidColorBrush x:Key="NotifErrorBackgroundBrush" Color="#3D2D2D" />
            <SolidColorBrush x:Key="NotifWarningBackgroundBrush" Color="#3D3A2D" />
            <SolidColorBrush x:Key="NotifInfoBackgroundBrush" Color="#2D3340" />
            <SolidColorBrush x:Key="NotifSuccessStripeBrush" Color="#A6E3A1" />
            <SolidColorBrush x:Key="NotifErrorStripeBrush" Color="#F38BA8" />
            <SolidColorBrush x:Key="NotifWarningStripeBrush" Color="#F9E2AF" />
            <SolidColorBrush x:Key="NotifInfoStripeBrush" Color="#89B4FA" />
        </ResourceDictionary>

        <!-- Light theme -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F5F7" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#E8E8EC" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBackgroundTransparentBrush" Color="#CCFFFFFF" />
            <SolidColorBrush x:Key="LinkForegroundBrush" Color="#0066CC" />

            <SolidColorBrush x:Key="NotifSuccessBackgroundBrush" Color="#E8F5E9" />
            <SolidColorBrush x:Key="NotifErrorBackgroundBrush" Color="#FFEBEE" />
            <SolidColorBrush x:Key="NotifWarningBackgroundBrush" Color="#FFF8E1" />
            <SolidColorBrush x:Key="NotifInfoBackgroundBrush" Color="#E3F2FD" />
            <SolidColorBrush x:Key="NotifSuccessStripeBrush" Color="#4CAF50" />
            <SolidColorBrush x:Key="NotifErrorStripeBrush" Color="#EF5350" />
            <SolidColorBrush x:Key="NotifWarningStripeBrush" Color="#FFA726" />
            <SolidColorBrush x:Key="NotifInfoStripeBrush" Color="#42A5F5" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Spacing tokens -->
    <Thickness x:Key="PageMargin">24,16,24,16</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="StackSpacing">0,0,0,12</Thickness>

    <x:Double x:Key="HeadingFontSize">24</x:Double>
    <x:Double x:Key="SubheadingFontSize">18</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>

</ResourceDictionary>
