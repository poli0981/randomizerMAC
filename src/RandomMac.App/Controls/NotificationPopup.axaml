<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:RandomMac.App.Services"
             x:Class="RandomMac.App.Controls.NotificationPopup"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Border.toast">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="MinWidth" Value="260" />
            <Setter Property="MaxWidth" Value="340" />
            <Setter Property="BoxShadow" Value="0 4 16 0 #60000000" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
    </UserControl.Styles>

    <ItemsControl ItemsSource="{Binding Notifications}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,8,8,0">
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="svc:NotificationItem" x:CompileBindings="True">
                <Border Classes="toast"
                        Background="{Binding Type, Converter={StaticResource NotifTypeToBrushConverter}, ConverterParameter=Background}"
                        BorderBrush="{Binding Type, Converter={StaticResource NotifTypeToBrushConverter}, ConverterParameter=Stripe}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{Binding Type, Converter={StaticResource NotifTypeToBrushConverter}, ConverterParameter=Stripe}"
                                   Text="{Binding Type, Converter={StaticResource NotifTypeToIconConverter}}" />
                        <TextBlock Text="{Binding Message}"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   MaxWidth="270" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
