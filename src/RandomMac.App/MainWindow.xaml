<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RandomMac.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RandomMac.App.ViewModels"
    xmlns:views="using:RandomMac.App.Views"
    xmlns:controls="using:RandomMac.App.Controls"
    Title="RANDOM MAC">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom titlebar: dragable region drawn by SetTitleBar(AppTitleBar) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="12,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon FontFamily="Segoe Fluent Icons"
                          Glyph="&#xF22C;"
                          FontSize="14"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="{Binding [App_Title], Source={StaticResource Loc}}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- NavigationView. Hamburger toggle expands/collapses the pane.
             Open: 200px (label + icon); Collapsed: 48px (icon-only). -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
                        IsPaneToggleButtonVisible="True"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        OpenPaneLength="200"
                        CompactPaneLength="48"
                        Header="{Binding CurrentPage.Title}"
                        MenuItemsSource="{Binding NavItems}"
                        SelectedItem="{Binding SelectedNav, Mode=TwoWay}">

            <NavigationView.MenuItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons"
                                  Glyph="{Binding Icon}"
                                  FontSize="16" />
                        <TextBlock Text="{Binding Label}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding Owner.IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </DataTemplate>
            </NavigationView.MenuItemTemplate>

            <!-- Page host with PageTemplateSelector pivot + notification overlay -->
            <Grid>
                <ContentControl Content="{Binding CurrentPage}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                    <ContentControl.ContentTemplateSelector>
                        <views:PageTemplateSelector>
                            <views:PageTemplateSelector.DashboardTemplate>
                                <DataTemplate x:DataType="vm:DashboardViewModel">
                                    <views:DashboardView />
                                </DataTemplate>
                            </views:PageTemplateSelector.DashboardTemplate>
                            <views:PageTemplateSelector.SettingsTemplate>
                                <DataTemplate x:DataType="vm:SettingsViewModel">
                                    <views:SettingsView />
                                </DataTemplate>
                            </views:PageTemplateSelector.SettingsTemplate>
                            <views:PageTemplateSelector.AboutTemplate>
                                <DataTemplate x:DataType="vm:AboutViewModel">
                                    <views:AboutView />
                                </DataTemplate>
                            </views:PageTemplateSelector.AboutTemplate>
                            <views:PageTemplateSelector.LogTemplate>
                                <DataTemplate x:DataType="vm:LogViewModel">
                                    <views:LogView />
                                </DataTemplate>
                            </views:PageTemplateSelector.LogTemplate>
                            <views:PageTemplateSelector.UpdateTemplate>
                                <DataTemplate x:DataType="vm:UpdateViewModel">
                                    <views:UpdateView />
                                </DataTemplate>
                            </views:PageTemplateSelector.UpdateTemplate>
                        </views:PageTemplateSelector>
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>

                <!-- Toast overlay (top-right) -->
                <controls:NotificationPopup x:Name="NotificationOverlay"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,12,12,0"
                                            IsHitTestVisible="False" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
