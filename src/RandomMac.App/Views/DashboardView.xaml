<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RandomMac.App.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.UI.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,8,0">
        <StackPanel Spacing="14" Padding="24,16,24,16">

            <!-- Adapter selector + refresh -->
            <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="{Binding [Dashboard_SelectAdapter], Source={StaticResource Loc}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Adapters}"
                          SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="Segoe Fluent Icons"
                                          Glyph="{Binding Type, Converter={StaticResource AdapterTypeToGlyphConverter}}"
                                          FontSize="14"
                                          Opacity="0.75" />
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Command="{Binding LoadAdaptersCommand}"
                        ToolTipService.ToolTip="{Binding [Dashboard_Refresh], Source={StaticResource Loc}}">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </Grid>

            <!-- Empty state: shown when no adapter is selected -->
            <InfoBar IsOpen="{Binding SelectedAdapter, Converter={StaticResource NullToBoolConverter}, ConverterParameter=invert}"
                     Title="Pick an adapter"
                     Message="Choose a network adapter from the dropdown above to view its MAC and start randomizing."
                     Severity="Informational"
                     IsClosable="False" />

            <!-- Adapter status bar -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">

                <!-- Connection icon — one visible at a time based on IsConnected -->
                <Grid Grid.Column="0" Width="16" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe Fluent Icons"
                              Glyph="&#xE703;"
                              FontSize="13"
                              Foreground="#A6E3A1"
                              Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <FontIcon FontFamily="Segoe Fluent Icons"
                              Glyph="&#xF384;"
                              FontSize="13"
                              Foreground="#F38BA8"
                              Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}" />
                </Grid>

                <TextBlock Grid.Column="1"
                           Text="{Binding AdapterType}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="12" />

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentVendor}"
                           VerticalAlignment="Center"
                           Opacity="0.55"
                           FontSize="12"
                           Margin="6,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <!-- 3 MAC info cards -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                <!-- Current -->
                <Border Grid.Column="0"
                        CornerRadius="8"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding [Dashboard_CurrentMac], Source={StaticResource Loc}}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentMacDisplay}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding CurrentVendor}"
                                       Opacity="0.6"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1"
                                    Command="{Binding CopyMacCommand}"
                                    CommandParameter="{Binding CurrentMacDisplay}"
                                    Padding="4"
                                    ToolTipService.ToolTip="{Binding [Dashboard_CopyTip], Source={StaticResource Loc}}">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="12" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Original -->
                <Border Grid.Column="1"
                        CornerRadius="8"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding [Dashboard_OriginalMac], Source={StaticResource Loc}}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding OriginalMacDisplay}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <Button Command="{Binding CopyMacCommand}"
                                CommandParameter="{Binding OriginalMacDisplay}"
                                Padding="4"
                                HorizontalAlignment="Right"
                                ToolTipService.ToolTip="{Binding [Dashboard_CopyTip], Source={StaticResource Loc}}">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Preview -->
                <Border Grid.Column="2"
                        CornerRadius="8"
                        Padding="12"
                        Background="{ThemeResource CardBackgroundBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding [Dashboard_PreviewMac], Source={StaticResource Loc}}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PreviewMac}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PreviewVendor}"
                                       Opacity="0.6"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1"
                                    Command="{Binding CopyMacCommand}"
                                    CommandParameter="{Binding PreviewMac}"
                                    IsEnabled="{Binding HasPreview}"
                                    Padding="4"
                                    ToolTipService.ToolTip="{Binding [Dashboard_CopyTip], Source={StaticResource Loc}}">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="12" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Action buttons. Ctrl+R = Randomize, Ctrl+Enter = Apply. -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding GeneratePreviewCommand}"
                        IsEnabled="{Binding IsChanging, Converter={StaticResource InverseBoolConverter}}"
                        ToolTipService.ToolTip="Ctrl+R">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="R" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8B1;" FontSize="13" />
                        <TextBlock Text="{Binding [Dashboard_Randomize], Source={StaticResource Loc}}" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding ApplyMacCommand}"
                        IsEnabled="{Binding HasPreview}"
                        Style="{ThemeResource AccentButtonStyle}"
                        ToolTipService.ToolTip="Ctrl+Enter">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE73E;" FontSize="13" />
                        <TextBlock Text="{Binding [Dashboard_Apply], Source={StaticResource Loc}}" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding RestoreOriginalCommand}"
                        IsEnabled="{Binding IsMacChanged}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7A7;" FontSize="13" />
                        <TextBlock Text="{Binding [Dashboard_Restore], Source={StaticResource Loc}}" />
                    </StackPanel>
                </Button>

                <ProgressRing IsActive="{Binding IsChanging}"
                              Width="20" Height="20"
                              VerticalAlignment="Center" />
            </StackPanel>

            <!-- Status (auto-collapses when StatusMessage is empty) -->
            <InfoBar IsOpen="{Binding HasStatusMessage}"
                     Message="{Binding StatusMessage}"
                     Severity="Informational"
                     IsClosable="True" />

            <!-- History grid -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <TextBlock Grid.Column="0"
                           Text="{Binding [Dashboard_RecentHistory], Source={StaticResource Loc}}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Command="{Binding ClearHistoryCommand}"
                        Content="{Binding [Dashboard_Clear], Source={StaticResource Loc}}"
                        Padding="10,4"
                        FontSize="12" />
            </Grid>

            <Border CornerRadius="6"
                    Background="{ThemeResource CardBackgroundBrush}"
                    MinHeight="120"
                    MaxHeight="220">
                <!--
                    DataGridColumn is not in the visual tree, so XAML
                    {Binding} on Header does NOT resolve (the Binding object
                    itself becomes the Header value, rendering as
                    "Microsoft.UI.Xaml.Data.Binding"). Header strings are
                    set + refreshed in DashboardView.xaml.cs.
                -->
                <tk:DataGrid x:Name="HistoryGrid"
                             ItemsSource="{Binding RecentHistory}"
                             AutoGenerateColumns="False"
                             HeadersVisibility="Column"
                             IsReadOnly="True"
                             GridLinesVisibility="Horizontal"
                             Background="Transparent">
                    <tk:DataGrid.Columns>
                        <tk:DataGridTextColumn Binding="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                                               Width="Auto" />
                        <tk:DataGridTextColumn Binding="{Binding AdapterName}"
                                               Width="*" />
                        <tk:DataGridTextColumn Binding="{Binding PreviousMac}"
                                               Width="Auto" />
                        <tk:DataGridTextColumn Binding="{Binding NewMac}"
                                               Width="Auto" />
                        <tk:DataGridTextColumn Binding="{Binding Success, Converter={StaticResource BoolToStatusConverter}}"
                                               Width="Auto" />
                    </tk:DataGrid.Columns>
                </tk:DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
