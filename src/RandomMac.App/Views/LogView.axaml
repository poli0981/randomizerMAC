<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RandomMac.App.ViewModels"
             xmlns:loc="using:RandomMac.App.Localization"
             x:Class="RandomMac.App.Views.LogView"
             x:CompileBindings="False">

    <DockPanel>
        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <TextBox Text="{Binding FilterText}"
                         Watermark="{loc:L Log_Filter}"
                         Width="220" Height="32"
                         CornerRadius="6" FontSize="12" />
                <TextBlock Text="{Binding LogCount, StringFormat='{}{0} entries'}"
                           VerticalAlignment="Center"
                           FontSize="12" Opacity="0.5" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Height="32" Padding="12,0" CornerRadius="6" FontSize="12"
                        Cursor="Hand" VerticalContentAlignment="Center"
                        Command="{Binding ExportLogCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Width="12" Height="12" Data="{StaticResource ExportIcon}" />
                        <TextBlock Text="{loc:L Log_Export}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Height="32" Padding="12,0" CornerRadius="6" FontSize="12"
                        Cursor="Hand" VerticalContentAlignment="Center"
                        Command="{Binding ClearLogCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Width="12" Height="12" Data="{StaticResource DeleteIcon}" />
                        <TextBlock Text="{loc:L Log_Clear}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Log output -->
        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="8" Padding="12">
            <ListBox ItemsSource="{Binding LogLines}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="11.5"
                                   TextWrapping="NoWrap"
                                   Opacity="0.85" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</UserControl>
