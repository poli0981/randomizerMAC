<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RandomMac.App.ViewModels"
             xmlns:loc="using:RandomMac.App.Localization"
             x:Class="RandomMac.App.Views.UpdateView"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,16" />
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="16">

        <!-- Current version + Status badge -->
        <Border Classes="card">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding CurrentVersionDisplay}"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="13" Opacity="0.7"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{Binding StatusCode, Converter={StaticResource StatusCodeToBrushConverter}}"
                        CornerRadius="12"
                        Padding="12,6"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding StatusBadge}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#1E1E2E" />
                </Border>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Classes="action-btn"
                    Command="{Binding CheckForUpdateCommand}"
                    IsEnabled="{Binding !IsChecking}"
                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Width="14" Height="14" Data="{StaticResource SearchIcon}" />
                    <TextBlock Text="{loc:L Update_Check}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Classes="action-btn"
                    Command="{Binding DownloadUpdateCommand}"
                    IsVisible="{Binding HasUpdate}"
                    IsEnabled="{Binding !IsDownloading}"
                    Background="#40A6E3A1">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Width="14" Height="14" Data="{StaticResource DownloadIcon}" />
                    <TextBlock Text="{loc:L Update_Download}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Classes="action-btn"
                    Command="{Binding OpenReleasePageCommand}"
                    IsVisible="{Binding HasUpdate}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Width="14" Height="14" Data="{StaticResource ExternalLinkIcon}" />
                    <TextBlock Text="{loc:L Update_ViewRelease}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <ProgressBar IsIndeterminate="True" Width="100" Height="4"
                         VerticalAlignment="Center" IsVisible="{Binding IsChecking}" />
            <ProgressBar IsIndeterminate="True" Width="100" Height="4"
                         VerticalAlignment="Center" IsVisible="{Binding IsDownloading}" />
        </StackPanel>

        <!-- Release notes -->
        <Border Classes="card" IsVisible="{Binding HasUpdate}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
                    <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}'}"
                               FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding PublishedDateDisplay}"
                               FontSize="11" Opacity="0.5" />
                </StackPanel>

                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Hidden">
                    <TextBlock Text="{Binding ReleaseNotes}"
                               FontSize="12.5"
                               TextWrapping="Wrap"
                               Opacity="0.8"
                               FontFamily="Cascadia Mono, Consolas, monospace" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </StackPanel>
</UserControl>
