<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RandomMac.App.ViewModels"
        xmlns:views="using:RandomMac.App.Views"
        xmlns:controls="using:RandomMac.App.Controls"
        xmlns:loc="using:RandomMac.App.Localization"
        x:Class="RandomMac.App.Views.MainWindow"
        x:CompileBindings="False"
        Title="RANDOM MAC"
        Width="880" Height="600"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Styles>
        <!-- Nav ListBox styling -->
        <Style Selector="ListBox.NavList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem">
            <Setter Property="Padding" Value="14 12" />
            <Setter Property="Margin" Value="4 2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="ListBox.NavList ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
        </Style>

        <!-- Titlebar buttons -->
        <Style Selector="Button.titlebar-btn">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.titlebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>
    </Window.Styles>

    <Panel>
    <Grid ColumnDefinitions="200,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                Padding="8">
            <DockPanel>
                <!-- App title in sidebar top -->
                <StackPanel DockPanel.Dock="Top" Margin="8,12,8,20">
                    <Panel Height="30" IsHitTestVisible="True"
                           Background="Transparent">
                        <TextBlock Text="{loc:L App_Title}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   VerticalAlignment="Center" />
                    </Panel>
                </StackPanel>

                <!-- Navigation -->
                <ListBox Classes="NavList"
                         ItemsSource="{Binding NavItems}"
                         SelectedIndex="{Binding SelectedNavIndex}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <PathIcon Width="18" Height="18"
                                          Data="{Binding Icon, Converter={x:Static views:MainWindow.IconConverter}}"
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                                <TextBlock Text="{Binding Label}"
                                           VerticalAlignment="Center"
                                           FontSize="14" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Padding="24,16">
            <DockPanel>
                <!-- Window controls (custom titlebar) -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="4"
                            Margin="0,0,0,12">
                    <Button Classes="titlebar-btn" Click="OnMinimizeClick"
                            Content="─" ToolTip.Tip="{loc:L Titlebar_Minimize}" />
                    <Button Classes="titlebar-btn" Click="OnCloseClick"
                            Content="✕" ToolTip.Tip="{loc:L Titlebar_Close}" />
                </StackPanel>

                <!-- Page header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding CurrentPage.Title}"
                           FontSize="24" FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <!-- Page content -->
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:AboutViewModel">
                            <views:AboutView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:UpdateViewModel">
                            <views:UpdateView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LogViewModel">
                            <views:LogView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DockPanel>
        </Border>
    </Grid>

    <!-- Notification overlay -->
    <controls:NotificationPopup x:Name="NotificationOverlay"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,48,12,0"
                                IsHitTestVisible="False" />
    </Panel>
</Window>
