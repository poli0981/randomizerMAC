<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RandomMac.App.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,8,0">
        <StackPanel Spacing="0" Padding="32,28,32,28">

            <!-- Hero: centered icon + name + version -->
            <StackPanel HorizontalAlignment="Center" Spacing="6">
                <FontIcon FontFamily="Segoe Fluent Icons"
                          Glyph="&#xF22C;"
                          FontSize="56"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{Binding AppName}"
                           FontSize="26"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Version}"
                           FontSize="13"
                           Opacity="0.55"
                           HorizontalAlignment="Center"
                           Margin="0,-2,0,0" />
            </StackPanel>

            <!-- Description -->
            <TextBlock Text="{Binding Description}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="520"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,24"
                       Opacity="0.85" />

            <!-- Inline links: GitHub profile, repo, license -->
            <StackPanel HorizontalAlignment="Center" Spacing="0" Margin="0,0,0,28">
                <HyperlinkButton Content="{Binding [About_GitHubProfile], Source={StaticResource Loc}}"
                                 NavigateUri="{Binding DeveloperUrl}"
                                 HorizontalAlignment="Center" />
                <HyperlinkButton Content="{Binding [About_GitHubRepo], Source={StaticResource Loc}}"
                                 NavigateUri="{Binding RepositoryUrl}"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{Binding License}"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Third-party section -->
            <TextBlock Text="{Binding [About_ThirdParty], Source={StaticResource Loc}}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Opacity="0.7"
                       Margin="0,0,0,8" />

            <ItemsControl ItemsSource="{Binding ThirdParties}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,5"
                              ColumnDefinitions="*,Auto,Auto,Auto"
                              ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Version}"
                                       Opacity="0.55"
                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding License}"
                                       Opacity="0.55"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <HyperlinkButton Grid.Column="3"
                                             Content="&#xE8A7;"
                                             FontFamily="Segoe Fluent Icons"
                                             FontSize="13"
                                             Padding="6,0"
                                             NavigateUri="{Binding Url}"
                                             ToolTipService.ToolTip="{Binding Url}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Legal text (small print at bottom) -->
            <TextBlock Text="{Binding [About_LegalText], Source={StaticResource Loc}}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Opacity="0.5"
                       Margin="0,20,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
