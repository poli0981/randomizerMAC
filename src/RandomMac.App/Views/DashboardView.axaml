<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RandomMac.App.ViewModels"
             xmlns:models="using:RandomMac.Core.Models"
             xmlns:loc="using:RandomMac.App.Localization"
             x:Class="RandomMac.App.Views.DashboardView"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Adapter selector row -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Adapters}"
                      SelectedItem="{Binding SelectedAdapter}"
                      PlaceholderText="{loc:L Dashboard_SelectAdapter}"
                      HorizontalAlignment="Stretch"
                      Height="40"
                      CornerRadius="6">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Type}" FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center"
                                       Width="55" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1" Classes="action"
                    Command="{Binding LoadAdaptersCommand}"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Width="14" Height="14" Data="{StaticResource RefreshIcon}" />
                    <TextBlock Text="{loc:L Dashboard_Refresh}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" RowDefinitions="Auto,16,Auto,16,*">

            <!-- MAC info cards -->
            <Grid Grid.Row="0" ColumnDefinitions="*,12,*,12,*">

                <!-- Current MAC -->
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{loc:L Dashboard_CurrentMac}" />
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                Command="{Binding CopyMacCommand}" CommandParameter="{Binding CurrentMacDisplay}"
                                ToolTip.Tip="{loc:L Dashboard_CopyTip}">
                            <TextBlock Classes="value" Text="{Binding CurrentMacDisplay}"
                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                        </Button>
                        <TextBlock Text="{Binding CurrentVendor}" FontSize="11" Opacity="0.5" Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
                            <TextBlock Text="{Binding AdapterType}" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Original MAC -->
                <Border Grid.Column="2" Classes="card">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{loc:L Dashboard_OriginalMac}" />
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                Command="{Binding CopyMacCommand}" CommandParameter="{Binding OriginalMacDisplay}"
                                ToolTip.Tip="{loc:L Dashboard_CopyTip}">
                            <TextBlock Classes="value" Text="{Binding OriginalMacDisplay}" Opacity="0.7" />
                        </Button>
                        <Button Classes="action" Margin="0,8,0,0" FontSize="11" Height="28" Padding="10,0"
                                Command="{Binding RestoreOriginalCommand}"
                                IsEnabled="{Binding !IsChanging}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Width="12" Height="12" Data="{StaticResource UndoIcon}" />
                                <TextBlock Text="{loc:L Dashboard_Restore}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Preview MAC -->
                <Border Grid.Column="4" Classes="card">
                    <StackPanel>
                        <TextBlock Classes="label" Text="{loc:L Dashboard_PreviewMac}" />
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                Command="{Binding CopyMacCommand}" CommandParameter="{Binding PreviewMac}"
                                ToolTip.Tip="{loc:L Dashboard_CopyTip}"
                                IsVisible="{Binding HasPreview}">
                            <TextBlock Classes="value" Text="{Binding PreviewMac}" Foreground="#A6E3A1" />
                        </Button>
                        <TextBlock Classes="value" Text="--"
                                   Opacity="0.3"
                                   IsVisible="{Binding !HasPreview}" />
                        <TextBlock Text="{Binding PreviewVendor}" FontSize="11" Opacity="0.5"
                                   Margin="0,2,0,0" IsVisible="{Binding HasPreview}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Action buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                <Button Classes="action"
                        Command="{Binding GeneratePreviewCommand}"
                        IsEnabled="{Binding IsConnected}"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Data="{StaticResource DiceIcon}" />
                        <TextBlock Text="{loc:L Dashboard_Randomize}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="action"
                        Command="{Binding ApplyMacCommand}"
                        IsEnabled="{Binding HasPreview}"
                        Background="#40A6E3A1"
                        IsVisible="{Binding HasPreview}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Data="{StaticResource CheckIcon}" />
                        <TextBlock Text="{loc:L Dashboard_Apply}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="action"
                        Command="{Binding RestoreOriginalCommand}"
                        IsEnabled="{Binding IsMacChanged}"
                        IsVisible="{Binding IsMacChanged}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Data="{StaticResource UndoIcon}" />
                        <TextBlock Text="{loc:L Dashboard_RevertFactory}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="action"
                        Command="{Binding RefreshAdapterCommand}"
                        IsEnabled="{Binding SelectedAdapter, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Data="{StaticResource RefreshIcon}" />
                        <TextBlock Text="{loc:L Dashboard_Refresh}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <ProgressBar IsIndeterminate="True"
                             Width="100" Height="4"
                             IsVisible="{Binding IsChanging}"
                             VerticalAlignment="Center" />
            </StackPanel>

            <!-- History table -->
            <Border Grid.Row="4" Classes="card">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="{loc:L Dashboard_RecentHistory}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="action" Height="26" Padding="8,0" FontSize="11"
                                Command="{Binding ClearHistoryCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Width="11" Height="11" Data="{StaticResource DeleteIcon}" />
                                <TextBlock Text="{loc:L Dashboard_Clear}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <DataGrid ItemsSource="{Binding RecentHistory}"
                              IsReadOnly="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              MaxHeight="200"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="80" />
                            <DataGridTextColumn Header="Adapter" Binding="{Binding AdapterName}" Width="*" />
                            <DataGridTextColumn Header="Previous" Binding="{Binding PreviousMac}" Width="140" />
                            <DataGridTextColumn Header="New" Binding="{Binding NewMac}" Width="140" />
                            <DataGridTemplateColumn Header="Status" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Success, Converter={StaticResource BoolToStatusConverter}}"
                                                   HorizontalAlignment="Center"
                                                   FontSize="14" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="8,6"
                Background="{DynamicResource CardBackgroundTransparentBrush}"
                CornerRadius="6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Opacity="0.7" />
        </Border>
    </Grid>
</UserControl>
