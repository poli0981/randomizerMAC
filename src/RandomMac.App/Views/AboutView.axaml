<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RandomMac.App.ViewModels"
             xmlns:loc="using:RandomMac.App.Localization"
             x:Class="RandomMac.App.Views.AboutView"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Border.section">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="Button.link-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource LinkForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.link-btn:pointerover">
            <Setter Property="Opacity" Value="0.75" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Spacing="0">

            <!-- App Info -->
            <Border Classes="section">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding AppName}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                    <TextBlock Text="{Binding Version, StringFormat='Version {0}'}"
                               FontSize="13" Opacity="0.6" />
                    <TextBlock Text="{Binding Description}"
                               FontSize="13" Opacity="0.8"
                               TextWrapping="Wrap" Margin="0,4,0,0" />

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,0">
                        <Button Classes="link-btn"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding RepositoryUrl}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Width="13" Height="13" Data="{StaticResource ExternalLinkIcon}"
                                          Foreground="{DynamicResource LinkForegroundBrush}" />
                                <TextBlock Text="{loc:L About_GitHubRepo}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="|" Opacity="0.3" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding License}"
                                   FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Developer -->
            <Border Classes="section">
                <StackPanel>
                    <TextBlock Classes="section-title" Text="{loc:L About_Developer}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Developer}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Classes="link-btn"
                                Command="{Binding OpenUrlCommand}"
                                CommandParameter="{Binding DeveloperUrl}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Width="12" Height="12" Data="{StaticResource ExternalLinkIcon}"
                                          Foreground="{DynamicResource LinkForegroundBrush}" />
                                <TextBlock Text="{loc:L About_GitHubProfile}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Third-party Libraries -->
            <Border Classes="section">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="section-title"
                               Text="{loc:L About_ThirdParty}" />

                    <ItemsControl ItemsSource="{Binding ThirdParties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,6" BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="link-btn"
                                                        FontWeight="SemiBold"
                                                        Command="{Binding $parent[ItemsControl].DataContext.OpenUrlCommand}"
                                                        CommandParameter="{Binding Url}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                        <PathIcon Width="10" Height="10" Data="{StaticResource ExternalLinkIcon}"
                                                                  Foreground="{DynamicResource LinkForegroundBrush}" />
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding Version}"
                                                           FontSize="11" Opacity="0.4"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11.5" Opacity="0.6" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding License}"
                                                       FontSize="10" Opacity="0.7" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Legal -->
            <Border Classes="section">
                <StackPanel>
                    <TextBlock Classes="section-title" Text="{loc:L About_Legal}" />
                    <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                               Text="{loc:L About_LegalText}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
