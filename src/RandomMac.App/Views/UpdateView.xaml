<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RandomMac.App.Views.UpdateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,8,0">
        <StackPanel Spacing="16" Padding="24,16,24,16">

            <!-- Status hero card -->
            <Border CornerRadius="10"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundBrush}">
                <Grid ColumnDefinitions="56,*" ColumnSpacing="16">

                    <!-- One state icon visible at a time -->
                    <Grid Grid.Column="0" Width="48" Height="48" VerticalAlignment="Top">
                        <ProgressRing IsActive="{Binding IsChecking}"
                                      Visibility="{Binding IsChecking, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Width="40" Height="40" />

                        <FontIcon FontFamily="Segoe Fluent Icons"
                                  Glyph="&#xE73E;"
                                  FontSize="40"
                                  Foreground="#A6E3A1"
                                  Visibility="{Binding IsUpToDateState, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <FontIcon FontFamily="Segoe Fluent Icons"
                                  Glyph="&#xE74A;"
                                  FontSize="40"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <FontIcon FontFamily="Segoe Fluent Icons"
                                  Glyph="&#xE7BA;"
                                  FontSize="40"
                                  Foreground="#F38BA8"
                                  Visibility="{Binding IsErrorState, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <FontIcon FontFamily="Segoe Fluent Icons"
                                  Glyph="&#xE946;"
                                  FontSize="40"
                                  Opacity="0.45"
                                  Visibility="{Binding IsIdle, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <!-- Version + status text -->
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentVersionDisplay}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Opacity="0.85"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LastCheckedDisplay}"
                                   Opacity="0.55"
                                   FontSize="11"
                                   Visibility="{Binding HasLastChecked, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Check button -->
            <Button Command="{Binding CheckForUpdateCommand}"
                    IsEnabled="{Binding IsChecking, Converter={StaticResource InverseBoolConverter}}"
                    HorizontalAlignment="Left"
                    Padding="20,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="Segoe Fluent Icons"
                              Glyph="&#xE72C;"
                              FontSize="13" />
                    <TextBlock Text="{Binding [Update_Check], Source={StaticResource Loc}}" />
                </StackPanel>
            </Button>

            <!-- Update available card -->
            <Border CornerRadius="10"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0,0,0,3"
                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding LatestVersion}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PublishedDateDisplay}"
                                   Opacity="0.6"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border CornerRadius="6"
                            Padding="14"
                            Background="{ThemeResource CardBackgroundTransparentBrush}">
                        <ScrollViewer MaxHeight="220"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding ReleaseNotes}"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Border>

                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding DownloadUpdateCommand}"
                                IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}"
                                Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="Segoe Fluent Icons"
                                          Glyph="&#xE896;"
                                          FontSize="13" />
                                <TextBlock Text="{Binding [Update_Download], Source={StaticResource Loc}}" />
                            </StackPanel>
                        </Button>

                        <HyperlinkButton Content="{Binding [Update_ViewRelease], Source={StaticResource Loc}}"
                                         NavigateUri="{Binding ReleaseUrl}" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
