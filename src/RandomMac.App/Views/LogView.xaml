<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="RandomMac.App.Views.LogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*">

        <!-- Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{Binding [Log_Filter], Source={StaticResource Loc}}" />

            <ToggleSwitch Grid.Column="1"
                          IsOn="{Binding AutoScroll, Mode=TwoWay}"
                          OnContent=""
                          OffContent="" />

            <Button Grid.Column="2"
                    Content="{Binding [Log_Clear], Source={StaticResource Loc}}"
                    Command="{Binding ClearLogCommand}" />

            <Button Grid.Column="3"
                    Content="{Binding [Log_Export], Source={StaticResource Loc}}"
                    Command="{Binding ExportLogCommand}" />
        </Grid>

        <!-- Counter -->
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,8"
                   Opacity="0.6"
                   FontSize="12">
            <Run Text="{Binding [Log_Entries], Source={StaticResource Loc}}" />
            <Run Text=":" />
            <Run Text="{Binding LogCount}" />
        </TextBlock>

        <!-- Log lines -->
        <Border Grid.Row="2"
                CornerRadius="6"
                Background="{ThemeResource CardBackgroundBrush}"
                Padding="2">
            <ScrollViewer x:Name="LogScroller">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                       FontSize="12"
                                       Padding="8,2"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
